  "keyFeatures": [
    "License activation on up to N machines with machine-limit enforcement",
    "Online license validation with heartbeat and grace period support",
    "Offline challenge-response activation for air-gapped machines",
    "Machine deactivation to free slots for new installs",
    "Customer account portal: license lookup, receipt viewing, machine management",
    "Shopify and WooCommerce webhook adapters for automatic license issuance on purchase",
    "Signed license files (Ed25519) with entitlement and machine binding",
    "JUCE C++ client library for plugin integration"
  ],
  "publicApiSurface": [
    "POST /api/licenses/activate",
    "POST /api/licenses/validate",
    "POST /api/licenses/refresh",
    "POST /api/licenses/deactivate",
    "POST /api/licenses/offline/challenge",

    "POST /api/licenses/recover",
    "POST /api/v1/licenses",
    "POST /api/webhooks/shopify/[tenantSlug]",
    "POST /api/webhooks/woocommerce/[tenantSlug]",
    "GET /api/account/licenses",
    "GET /api/account/order-receipt"
  ]
